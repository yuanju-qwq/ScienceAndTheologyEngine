{
  "format": "snt.ui.packed_scene",
  "version": 1,
  "root": {
    "type": "frame",
    "id": "research_root",
    "layout": {
      "width": 360,
      "height": 220,
      "padding": [12, 12, 12, 12]
    },
    "background": {
      "color": [16, 23, 34, 244],
      "radius": 6
    },
    "children": [
      {
        "type": "linear",
        "id": "research_panel",
        "layout": {
          "orientation": "vertical",
          "spacing": 8
        },
        "children": [
          {
            "type": "text",
            "id": "research_title",
            "text": "Research Archive",
            "text_style": {
              "size": 18,
              "color": [230, 236, 245, 255]
            }
          },
          {
            "type": "button",
            "id": "research_claim",
            "text": "Claim",
            "action": "research.claim"
          }
        ]
      }
    ]
  }
}
